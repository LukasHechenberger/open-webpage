{
  "name": "@lhechenberger/open-webpage",
  "version": "0.0.1",
  "description": "Open a webpage in a custom window from nodejs",
  "license": "MIT",
  "main": "js/async.mjs",
  "types": "js/async.d.mts",
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "dev": "npx chokidar-cli src/lib.rs -c 'yarn build' --initial",
    "format": "prettier .",
    "postinstall": "ignore-sync .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest",
    "universal": "napi universal",
    "version": "napi version"
  },
  "dependencies": {
    "debug": "^4.4.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.13.5",
    "ignore-sync": "^8.0.0",
    "prettier": "^3.5.2",
    "prettier-plugin-packagejson": "^2.5.8",
    "vitest": "^3.0.7"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">= 10"
  },
  "napi": {
    "name": "open-webpage",
    "triples": {
      "additional": [
        "aarch64-apple-darwin"
      ]
    }
  }
}
