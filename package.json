{
  "name": "@lhechenberger/open-webpage",
  "version": "0.0.8",
  "description": "Open a webpage in a custom window from nodejs",
  "license": "MIT",
  "main": "./out/index.js",
  "module": "./out/index.mjs",
  "types": "./out/index.d.ts",
  "bin": {
    "open-webpage": "./out/bin/index.mjs"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "pnpm build:release",
    "build:debug": "napi build --platform",
    "build:js": "tsup",
    "build:release": "napi build --platform --release",
    "postbuild": "pnpm build:js",
    "dev": "chokidar src/lib.rs -c 'pnpm build:release && tsup-dev' --initial",
    "dev:rust": "cargo watch build",
    "format": "prettier .",
    "ignore-sync": "ignore-sync .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest",
    "universal": "napi universal",
    "version": "napi version"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "commander": "^14.0.3",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@lhechenberger/tsup-dev": "^0.0.0",
    "@lhechenberger/tsup-watch-monorepo": "^0.1.0",
    "@napi-rs/cli": "^2.18.4",
    "@toolsync/template": "^0.1.2",
    "@types/node": "^22.13.5",
    "chokidar-cli": "^3.0.0",
    "ignore-sync": "^8.0.0",
    "json-schema-to-ts": "^3.1.1",
    "prettier": "^3.5.2",
    "prettier-plugin-packagejson": "^2.5.8",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">= 18"
  },
  "napi": {
    "name": "open-webpage",
    "npmClient": "pnpm",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  }
}
